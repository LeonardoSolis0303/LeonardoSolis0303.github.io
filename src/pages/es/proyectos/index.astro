---
import Base from '../../../layouts/Base.astro';
import Listing from '../../../components/Listing.astro';
import { getCollection } from 'astro:content';
import { byLang } from '../../../lib/content';
import { t } from '../../../lib/i18n';

const ui = t('es');
const all = await getCollection('projects');
const entries = byLang(all, 'es');
---

<Base
  lang="es"
  title={`${ui.projects.title} — Leonardo Solis`}
  description={ui.projects.subtitle}
  alternateUrl="/en/projects"
  canonical="/es/proyectos"
>
  <header class="page-header">
    <p class="kicker">proyectos</p>
    <h1 class="page-title">{ui.projects.title}</h1>
    <p class="page-subtitle">{ui.projects.subtitle}</p>
  </header>
  <div class="page-body">
    <Listing entries={entries} lang="es" empty={ui.projects.empty} />
  </div>
</Base>
