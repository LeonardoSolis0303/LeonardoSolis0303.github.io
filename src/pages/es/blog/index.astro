---
import Base from '../../../layouts/Base.astro';
import Listing from '../../../components/Listing.astro';
import { getCollection } from 'astro:content';
import { byLang } from '../../../lib/content';
import { t } from '../../../lib/i18n';

const ui = t('es');
const all = await getCollection('blog');
const entries = byLang(all, 'es');
---

<Base
  lang="es"
  title={`${ui.blog.title} — Leonardo Solis`}
  description={ui.blog.subtitle}
  alternateUrl="/en/blog"
  canonical="/es/blog"
>
  <header class="page-header">
    <p class="kicker">blog</p>
    <h1 class="page-title">{ui.blog.title}</h1>
    <p class="page-subtitle">{ui.blog.subtitle}</p>
  </header>
  <div class="page-body">
    <Listing entries={entries} lang="es" empty={ui.blog.empty} />
  </div>
</Base>
