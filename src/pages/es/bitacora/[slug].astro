---
import Base from '../../../layouts/Base.astro';
import { t } from '../../../lib/i18n';
import { data, g, blogSlug, routeFor, catClass } from '../../../lib/site';
export function getStaticPaths(){ return data.BITACORA.map((item)=>({params:{slug:blogSlug(item)}, props:{item}})); }
const { item }=Astro.props; const lang='es'; const ui=t(lang);
---
<Base lang="es" title={`${g(item,'titulo',lang)} — Bitácora`} description={g(item,'extracto',lang)} canonical={routeFor(lang,'blog',blogSlug(item))} alternateUrl={routeFor('en','blog',blogSlug(item))} type="article">
  <article class="page-body detail-page"><a href={routeFor(lang,'blog')} class="back-link">{ui.blog.back}</a><div class="detail-meta"><span>{item.fecha}</span><span class:list={['chip',catClass(item.categoria)]}>{g(item,'catLabel',lang)}</span>{item.destacada && <span class="featured-star">★ {ui.blog.featured}</span>}<span>{item.min} {ui.blog.readingTime}</span></div><h1 class="detail-title">{g(item,'titulo',lang)}</h1>{item.imagen && <figure class="cover-figure"><img src={item.imagen} alt="" />{g(item,'pieDeFoto',lang)&&<figcaption>{g(item,'pieDeFoto',lang)}</figcaption>}</figure>}<div class="prose">{g(item,'cuerpo',lang).split('\n\n').map((p)=><p>{p}</p>)}</div></article>
</Base>
