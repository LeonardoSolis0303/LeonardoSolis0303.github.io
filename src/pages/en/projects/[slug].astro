---
import Base from '../../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';
import { byLang, counterpart, entryUrl, translationKey } from '../../../lib/content';
import { t, formatDate } from '../../../lib/i18n';

export async function getStaticPaths() {
  const all = await getCollection('projects');
  const allBlog = await getCollection('blog');
  return byLang(all, 'en').map(entry => ({
    params: { slug: entry.data.slug },
    props: { entry, all, allBlog },
  }));
}

const { entry, all, allBlog } = Astro.props;
const { Content } = await render(entry);

const ui = t('en');
const alt = counterpart(entry, all);
const altUrl = alt ? entryUrl(alt) : undefined;

// Posts relacionados: el frontmatter trae translationKeys; los emparejamos
// al inglés del blog.
const blogEn = byLang(allBlog, 'en');
const related = entry.data.relatedPosts
  .map(key => blogEn.find(b => translationKey(b) === key))
  .filter((b): b is NonNullable<typeof b> => Boolean(b));

const status = entry.data.status;
const statusLabel = ui.status[status as keyof typeof ui.status] ?? status;
---

<Base
  lang="en"
  title={`${entry.data.title} — Projects`}
  description={entry.data.description}
  type="article"
  publishedTime={entry.data.date}
  canonical={entryUrl(entry)}
  alternateUrl={altUrl}
>
  <article>
    <header class="page-header">
      <p class="kicker">project · {formatDate(entry.data.date, 'en')}</p>
      <h1 class="page-title">{entry.data.title}</h1>
      <p class="page-subtitle">{entry.data.description}</p>
      <div class="project-meta" style="margin-top:14px">
        <span class:list={['status-pill', `status-pill--${status}`]}>{statusLabel}</span>
        {entry.data.tags.length > 0 && (
          <>
            <span class="project-meta__sep"></span>
            <span style="font-family:var(--font-mono); font-size:9px; color:var(--dim); letter-spacing:0.06em">
              {entry.data.tags.join(' · ')}
            </span>
          </>
        )}
      </div>
    </header>

    <div class="page-body">
      {altUrl && (
        <a href={altUrl} class="lang-switch">{ui.projects.otherLang} →</a>
      )}

      <div class="prose">
        <Content />
      </div>

      {entry.data.repo && (
        <section class="project-section">
          <div class="project-section__label">{ui.projects.links}</div>
          <a href={entry.data.repo} class="project-link" target="_blank" rel="noopener">
            <span class="project-link__icon">↗</span>
            {ui.projects.repo}
          </a>
        </section>
      )}

      {related.length > 0 && (
        <section class="project-section">
          <div class="project-section__label">{ui.projects.relatedPosts}</div>
          <div class="entry-list">
            {related.map(post => (
              <a href={entryUrl(post)} class="entry">
                <time class="entry__date" datetime={post.data.date.toISOString()}>
                  {formatDate(post.data.date, 'en')}
                </time>
                <div>
                  <h3 class="entry__title">{post.data.title}</h3>
                  <p class="entry__excerpt">{post.data.description}</p>
                </div>
              </a>
            ))}
          </div>
        </section>
      )}

      <a href="/en/projects" class="back-link">{ui.projects.back}</a>
    </div>
  </article>
</Base>
