---
import Base from '../../../layouts/Base.astro';
import { t } from '../../../lib/i18n';
import { data, g, researchSlug, routeFor, lineClass, statusLabel, statusInfo } from '../../../lib/site';
export function getStaticPaths() { return data.RESEARCH.map((item)=>({ params:{slug:researchSlug(item)}, props:{item} })); }
const { item } = Astro.props; const lang='en'; const ui=t(lang);
---
<Base lang="en" title={`${g(item,'titulo',lang)} — Research`} description={g(item,'desc',lang)} canonical={routeFor(lang,'research',researchSlug(item))} alternateUrl={routeFor('es','research',researchSlug(item))}>
  <article class="page-body detail-page">
    <a href={routeFor(lang,'research')} class="back-link">{ui.research.back}</a>
    <div class="detail-meta"><span class:list={['chip',lineClass(item.linea)]}>{g(item,'lineaLabel',lang)}</span><span class:list={['status-pill',statusInfo[item.status]?.cls]}>{statusLabel(item.status,lang)}</span></div>
    <h1 class="detail-title">{g(item,'titulo',lang)}</h1>
    <p class="detail-desc">{g(item,'desc',lang)}</p>
    <div class="detail-grid">{item.lugar && <div><strong>{ui.research.location}</strong><span>{item.lugar}</span></div>}{item.asesor && <div><strong>{ui.research.advisor}</strong><span>{item.asesor}</span></div>}</div>
    <div class="tag-row detail-tags">{item.tags.map((tag)=><span>{tag}</span>)}</div>
  </article>
</Base>
