---
import Base from '../../../layouts/Base.astro';
import { t } from '../../../lib/i18n';
import { g, teachingItems, teachingSlug, routeFor } from '../../../lib/site';
export function getStaticPaths(){ return teachingItems().map((item)=>({params:{slug:teachingSlug(item)}, props:{item}})); }
const { item } = Astro.props; const lang='en'; const ui=t(lang);
---
<Base lang="en" title={`${g(item,'titulo',lang)} — Teaching`} description={g(item,'desc',lang)} canonical={routeFor(lang,'teaching',teachingSlug(item))} alternateUrl={routeFor('es','teaching',teachingSlug(item))}>
  <article class="page-body detail-page"><a href={`${routeFor(lang,'teaching')}#${item.kind}`} class="back-link">{ui.teaching.back}</a><div class="kicker">{item.kind}</div><h1 class="detail-title">{g(item,'titulo',lang)}</h1><p class="detail-desc">{g(item,'desc',lang)}</p>{item.enunciado && <section class="prose"><h2>{ui.teaching.statement}</h2><p>{g(item,'enunciado',lang)}</p></section>}{item.solucion && <section class="prose"><h2>{ui.teaching.solution}</h2><p>{g(item,'solucion',lang)}</p></section>}<h2 class="detail-section-title">{ui.teaching.topics}</h2><div class="tag-row detail-tags">{(item.tags || item.temas || []).map((s)=><span>{s}</span>)}</div></article>
</Base>
