---
import '../styles/home.css';
import { t, routes, type Lang } from '../lib/i18n';
import { data, g, routeFor, blogSlug, researchSlug, quantSlug } from '../lib/site';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const ui = t(lang);
const r = routes[lang];
const latest = data.BITACORA[0];
const recentPosts = data.BITACORA.slice(0,3);
const featuredResearch = data.RESEARCH.slice(0,3);
const featuredQuant = data.QUANT.slice(0,2);
const shortcuts = [
  { label: ui.home.latestPost, sub: latest.fecha, href: routeFor(lang,'blog',blogSlug(latest)) },
  { label: ui.home.mathComps, sub: null, href: `${r.teaching}#problemas` },
  { label: ui.home.problems, sub: null, href: `${r.teaching}#problemas` },
  { label: ui.home.classes, sub: null, href: `${r.teaching}#presenciales` },
];
---

<div class="home">
  <section class="hero">
    <img src="/assets/pizarron.jpg" alt="" class="hero__img" />
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <div class="hero__eyebrow">{ui.home.eyebrow}</div>
      <h1 class="hero__name">Leonardo <em>Solis</em></h1>
      <div class="hero__role">{ui.home.role}</div>
    </div>
  </section>

  <div class="home__body">
    <div class="home__grid">
      <div>
        <div class="home__blurb-eyebrow">{ui.home.aboutLabel}</div>
        <p class="home__blurb">{ui.home.blurb}</p>
      </div>
      <div>
        <div class="home__blurb-eyebrow">{ui.home.shortcuts}</div>
        {shortcuts.map(s => (
          <a href={s.href} class="home__shortcut">
            <span class="home__shortcut-left">{s.label}</span>
            {s.sub && <span class="home__shortcut-sub">{s.sub}</span>}
          </a>
        ))}
        <a href="/assets/cv.pdf" download class="btn-outline btn-outline--dark home__cv"><span style="font-size:11px">↓</span>{ui.home.downloadCV}</a>
      </div>
    </div>

    <section class="home__section">
      <div class="home__section-title"><span>{ui.home.recentPosts}</span><a href={r.blog}>{ui.home.seeAll} →</a></div>
      {recentPosts.map(p => (
        <a href={routeFor(lang,'blog',blogSlug(p))} class="home__entry">
          <div class="home__entry-date">{p.fecha}</div>
          <div><div class="home__entry-title">{p.destacada ? '★ ' : ''}{g(p,'titulo',lang)}</div><p class="home__entry-desc">{g(p,'extracto',lang)}</p></div>
        </a>
      ))}
    </section>

    <section class="home__section">
      <div class="home__section-title"><span>{ui.home.featuredResearch}</span><a href={r.research}>{ui.home.seeAll} →</a></div>
      {featuredResearch.map(p => (
        <a href={routeFor(lang,'research',researchSlug(p))} class="home__entry">
          <div class="home__entry-date">{g(p,'lineaLabel',lang)}</div>
          <div><div class="home__entry-title">{g(p,'titulo',lang)}</div><p class="home__entry-desc">{g(p,'desc',lang)}</p></div>
        </a>
      ))}
    </section>

    <section class="home__section">
      <div class="home__section-title"><span>{ui.home.featuredQuant}</span><a href={r.quant}>{ui.home.seeAll} →</a></div>
      {featuredQuant.map(p => (
        <a href={routeFor(lang,'quant',quantSlug(p))} class="home__entry">
          <div class="home__entry-date">{p.periodo}</div>
          <div><div class="home__entry-title">{g(p,'titulo',lang)}</div><p class="home__entry-desc">{g(p,'desc',lang)}</p></div>
        </a>
      ))}
    </section>
  </div>
</div>
