---
import { type Lang, formatDateShort } from '../lib/i18n';
import { entryUrl } from '../lib/content';
import type { CollectionEntry } from 'astro:content';

interface Props {
  entries: (CollectionEntry<'blog'> | CollectionEntry<'projects'>)[];
  lang: Lang;
  empty: string;
}

const { entries, lang, empty } = Astro.props;
---

{entries.length === 0 ? (
  <p style="color:var(--dim); font-style:italic">{empty}</p>
) : (
  <div class="entry-list">
    {entries.map(e => {
      const status = (e.collection === 'projects') ? (e.data as any).status : null;
      return (
        <a href={entryUrl(e)} class="entry">
          <time class="entry__date" datetime={e.data.date.toISOString()}>
            {formatDateShort(e.data.date, lang)}
          </time>
          <div>
            {status && status !== 'active' && (
              <span class:list={['status-pill', `status-pill--${status}`]} style="margin-bottom:6px; display:inline-flex">
                {status}
              </span>
            )}
            <h2 class="entry__title">{e.data.title}</h2>
            {e.data.tags.length > 0 && (
              <div class="entry__meta">
                {e.data.tags.slice(0, 4).map(tag => <span>#{tag}</span>)}
              </div>
            )}
            <p class="entry__excerpt">{e.data.description}</p>
          </div>
        </a>
      );
    })}
  </div>
)}
