---
import { t, routes, type Lang } from '../lib/i18n';

interface Props { lang: Lang; variant?: 'dark' | 'light'; altUrl?: string; }
const { lang, variant = 'light', altUrl } = Astro.props;
const r = routes[lang];
const otherLang: Lang = lang === 'en' ? 'es' : 'en';
const otherUrl = altUrl ?? routes[otherLang].home;
const ui = t(lang);
const path = Astro.url.pathname;
const norm = (s: string) => s.replace(/\/$/, '') || '/';
const isActive = (href: string) => norm(path) === norm(href) || norm(path).startsWith(norm(href) + '/');

const navItems = [
  { href: r.home, label: ui.nav.home },
  { href: r.cv, label: ui.nav.cv },
  { href: r.research, label: ui.nav.research },
  { href: r.quant, label: ui.nav.quant },
  { href: r.teaching, label: ui.nav.teaching },
  { href: r.reviews, label: ui.nav.reviews },
  { href: r.blog, label: ui.nav.blog },
];
const sidebarClass = `sidebar${variant === 'dark' ? ' sidebar--dark' : ''}`;
---

<nav class={sidebarClass} aria-label={lang === 'en' ? 'Main navigation' : 'Navegación principal'}>
  <a href={r.home} class="sidebar__brand">
    <div class="sidebar__monogram">L.S.</div>
    <div class="sidebar__name">Leonardo Solis</div>
  </a>

  <div class="sidebar__nav">
    {navItems.map(item => (
      <a href={item.href} class:list={['sidebar__link', { 'sidebar__link--active': isActive(item.href) }]}>{item.label}</a>
    ))}
  </div>

  <div class="sidebar__footer">
    <a href="https://github.com/LeonardoSolis0303" class="sidebar__social" rel="me">GitHub</a>
    <a href="https://linkedin.com/in/" class="sidebar__social" rel="me">LinkedIn</a>
    <div class="sidebar__lang" aria-label={lang === 'en' ? 'Language' : 'Idioma'}>
      <a href={lang === 'en' ? Astro.url.pathname : otherUrl} class:list={[{ 'is-active': lang === 'en' }]}>EN</a>
      <span class="sidebar__lang-sep">·</span>
      <a href={lang === 'es' ? Astro.url.pathname : otherUrl} class:list={[{ 'is-active': lang === 'es' }]}>ES</a>
    </div>
  </div>
</nav>
